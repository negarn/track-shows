# Copy these values into `.env.local` and keep `.env.local` uncommitted.
# Optional: override the default local persistence directory.
# TRACK_SHOWS_DATA_DIR=/absolute/path/to/track-shows-data

# Optional: set the externally reachable origin for a single trusted deployment.
# Use the exact scheme and host, such as https://track-shows.example.com.
# This is a same-origin gate for OAuth callbacks and API requests, not user authentication.
# TRACK_SHOWS_PUBLIC_ORIGIN=https://track-shows.example.com

# Cloud sync credentials are optional.
# Create an OAuth app in the provider console, then fill in the matching values.
TRACK_SHOWS_GOOGLE_DRIVE_CLIENT_ID=
TRACK_SHOWS_GOOGLE_DRIVE_CLIENT_SECRET=
TRACK_SHOWS_DROPBOX_CLIENT_ID=
TRACK_SHOWS_DROPBOX_CLIENT_SECRET=
